# Copy these into your Netlify site's Environment Variables (Site settings > Environment variables).
# Nothing here is read from a local .env file in production — Netlify Functions read
# process.env directly from the values you set in the Netlify UI.

# Supabase (Project Settings > API)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Anon key is safe to expose to the browser — it's gated by Row Level Security.
SUPABASE_ANON_KEY=

# Resend (resend.com > API Keys) — used to email homeowners + contractors
RESEND_API_KEY=
LEADS_FROM_EMAIL=leads@epoxygaragefloors.ai

# Stripe (dashboard.stripe.com > Developers > API keys)
STRIPE_SECRET_KEY=
# Price ID for the Premium installer monthly subscription (Products > Premium Installer)
STRIPE_PREMIUM_PRICE_ID=
# From the webhook endpoint you create pointing at /api/stripe-webhook
STRIPE_WEBHOOK_SECRET=

# Used to build success/cancel redirect URLs after Stripe Checkout
SITE_URL=https://epoxygaragefloors.ai
